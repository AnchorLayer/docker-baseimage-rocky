            {
              "id": "CVE-2026-42767-openssl",
              "name": "RpmMatcherExactDirectMatch",
              "shortDescription": {
                "text": "CVE-2026-42767 low vulnerability for openssl package"
              },
              "fullDescription": {
                "text": "A flaw was found in OpenSSL. An attacker controlling a Certificate Management Protocol (CMP) server, or acting as a man-in-the-middle, could craft a malicious CMP response. This response, containing a Certificate Request Message Format (CRMF) CertRepMessage with a specific malformed EncryptedValue structure, would trigger a NULL pointer dereference in the OpenSSL CMP client. This vulnerability leads to a crash of the application, resulting in a Denial of Service (DoS)."
              },
              "helpUri": "https://access.redhat.com/security/cve/CVE-2026-42767",
              "help": {
                "text": "Vulnerability CVE-2026-42767\nSeverity: low\nPackage: openssl\nVersion: 1:3.5.5-3.el9_8\nFix Version: 1:3.5.5-4.el9_8\nType: rpm\nLocation: /var/lib/rpm/rpmdb.sqlite\nData Namespace: redhat:distro:redhat:9\nLink: [CVE-2026-42767](https://access.redhat.com/security/cve/CVE-2026-42767)",
