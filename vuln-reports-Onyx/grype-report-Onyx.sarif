              },
              "helpUri": "https://github.com/anchore/grype",
              "help": {
                "text": "Vulnerability CVE-2026-31790\nSeverity: medium\nPackage: openssl-libs\nVersion: 1:3.5.1-7.el9_7\nFix Version: \nType: rpm\nLocation: /var/lib/rpm/rpmdb.sqlite\nData Namespace: redhat:distro:redhat:9\nLink: [CVE-2026-31790](https://access.redhat.com/security/cve/CVE-2026-31790)",
