            {
              "id": "CVE-2026-28386-openssl",
              "name": "RpmMatcherExactDirectMatch",
              "shortDescription": {
                "text": "CVE-2026-28386 low vulnerability for openssl package"
              },
              "fullDescription": {
                "text": "A flaw was found in openssl. Applications using AES-CFB128 encryption or decryption on systems with AVX-512 and VAES support may experience a Denial of Service (DoS). This occurs when processing partial cipher blocks, specifically if the input buffer ends at a memory page boundary and the subsequent page is unmapped. This can lead to an out-of-bounds read of up to 15 bytes and a potential application crash."
              },
              "helpUri": "https://github.com/anchore/grype",
              "help": {
                "text": "Vulnerability CVE-2026-28386\nSeverity: low\nPackage: openssl\nVersion: 1:3.5.1-7.el9_7\nFix Version: \nType: rpm\nLocation: /var/lib/rpm/rpmdb.sqlite\nData Namespace: redhat:distro:redhat:9\nLink: [CVE-2026-28386](https://access.redhat.com/security/cve/CVE-2026-28386)",
