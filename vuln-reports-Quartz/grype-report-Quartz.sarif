            {
              "id": "CVE-2026-5545-libcurl",
              "name": "RpmMatcherExactIndirectMatch",
              "shortDescription": {
                "text": "CVE-2026-5545 medium vulnerability for libcurl package"
              },
              "fullDescription": {
                "text": "A flaw was found in libcurl. An application using libcurl that performs an authenticated HTTP(S) request after a Negotiate-authenticated one to the same host may incorrectly reuse the previous connection. This authentication bypass vulnerability allows the second request to be sent over a connection authenticated with different credentials, potentially leading to unauthorized access or information disclosure."
              },
