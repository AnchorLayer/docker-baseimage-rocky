            {
              "id": "CVE-2025-10148-curl",
              "name": "RpmMatcherExactDirectMatch",
              "shortDescription": {
                "text": "CVE-2025-10148 low vulnerability for curl package"
              },
              "fullDescription": {
                "text": "A flaw was found in curl. The use of a predictable WebSocket mask pattern allows a malicious server to induce traffic that an intermediary proxy (whether configured or transparent) will misinterpret as a standard HTTP request. This confusion leads to a cache poisoning attack, where the proxy stores the server's malicious content and serves it to all users of that proxy."
              },
              "helpUri": "https://github.com/anchore/grype",
