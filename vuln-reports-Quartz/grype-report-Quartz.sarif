            {
              "id": "CVE-2026-11352-curl",
              "name": "RpmMatcherExactDirectMatch",
              "shortDescription": {
                "text": "CVE-2026-11352 high vulnerability for curl package"
              },
              "fullDescription": {
                "text": "A flaw was found in curl and libcurl. A malicious HTTP/3 server can exploit an issue in the QUIC UDP receive function by continuously streaming empty UDP datagrams. This can lead to a remote denial of service (DoS) against a curl or libcurl client, as the helper function discards zero-length UDP datagrams before counting them toward the per-call packet budget, causing the client to indefinitely stall."
              },
              "helpUri": "https://access.redhat.com/security/cve/CVE-2026-11352",
              "help": {
                "text": "Vulnerability CVE-2026-11352\nSeverity: high\nPackage: curl\nVersion: 8.12.1-4.el10\nFix Version: \nType: rpm\nLocation: /usr/lib/sysimage/rpm/rpmdb.sqlite\nData Namespace: redhat:distro:redhat:10\nLink: [CVE-2026-11352](https://access.redhat.com/security/cve/CVE-2026-11352)",
