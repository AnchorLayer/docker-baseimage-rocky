            {
              "id": "CVE-2026-8925-curl",
              "name": "RpmMatcherExactDirectMatch",
              "shortDescription": {
                "text": "CVE-2026-8925 high vulnerability for curl package"
              },
              "fullDescription": {
                "text": "A flaw was found in curl. The logic handling SASL (Simple Authentication and Security Layer) authentication could lead to a double-free vulnerability. This occurs because the GSASL context may be deallocated twice without clearing the pointer, potentially leading to memory corruption. An attacker could exploit this to cause a denial of service or potentially execute arbitrary code."
              },
              "helpUri": "https://access.redhat.com/security/cve/CVE-2026-8925",
              "help": {
                "text": "Vulnerability CVE-2026-8925\nSeverity: high\nPackage: curl\nVersion: 8.12.1-4.el10\nFix Version: \nType: rpm\nLocation: /usr/lib/sysimage/rpm/rpmdb.sqlite\nData Namespace: redhat:distro:redhat:10\nLink: [CVE-2026-8925](https://access.redhat.com/security/cve/CVE-2026-8925)",
