            {
              "id": "CVE-2026-28389-openssl",
              "name": "RpmMatcherExactDirectMatch",
              "shortDescription": {
                "text": "CVE-2026-28389 low vulnerability for openssl package"
              },
              "fullDescription": {
                "text": "A flaw was found in OpenSSL. A remote attacker could exploit this by sending a specially crafted Cryptographic Message Syntax (CMS) EnvelopedData message with KeyAgreeRecipientInfo. This vulnerability arises because the software attempts to process an optional field without verifying its existence, leading to a NULL pointer dereference. This can result in a Denial of Service (DoS) for applications that handle untrusted CMS data."
              },
              "helpUri": "https://access.redhat.com/security/cve/CVE-2026-28389",
              "help": {
                "text": "Vulnerability CVE-2026-28389\nSeverity: low\nPackage: openssl\nVersion: 1:1.1.1k-15.el8_10\nFix Version: \nType: rpm\nLocation: /var/lib/rpm/Packages\nData Namespace: redhat:distro:redhat:8\nLink: [CVE-2026-28389](https://access.redhat.com/security/cve/CVE-2026-28389)",
