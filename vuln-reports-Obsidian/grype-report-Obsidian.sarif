            {
              "id": "CVE-2026-27171-zlib",
              "name": "RpmMatcherExactDirectMatch",
              "shortDescription": {
                "text": "CVE-2026-27171 low vulnerability for zlib package"
              },
              "fullDescription": {
                "text": "A flaw was found in zlib. An attacker providing specially crafted input to the `crc32_combine64` or `crc32_combine_gen64` functions could trigger an infinite loop within the `x2nmodp` function. This leads to excessive CPU consumption, which can result in a Denial of Service (DoS) for the affected system."
              },
              "helpUri": "https://access.redhat.com/security/cve/CVE-2026-27171",
