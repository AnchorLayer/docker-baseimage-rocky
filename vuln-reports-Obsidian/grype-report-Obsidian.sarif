            {
              "id": "CVE-2025-5915-libarchive",
              "name": "RpmMatcherExactDirectMatch",
              "shortDescription": {
                "text": "CVE-2025-5915 low vulnerability for libarchive package"
              },
              "fullDescription": {
                "text": "A vulnerability has been identified in the libarchive library. This flaw can lead to a heap buffer over-read due to the size of a filter block potentially exceeding the Lempel-Ziv-Storer-Schieber (LZSS) window. This means the library may attempt to read beyond the allocated memory buffer, which can result in unpredictable program behavior, crashes (denial of service), or the disclosure of sensitive information from adjacent memory regions."
              },
              "helpUri": "https://access.redhat.com/security/cve/CVE-2025-5915",
              "help": {
                "text": "Vulnerability CVE-2025-5915\nSeverity: low\nPackage: libarchive\nVersion: 3.3.3-7.el8_10\nFix Version: \nType: rpm\nLocation: /var/lib/rpm/Packages\nData Namespace: redhat:distro:redhat:8\nLink: [CVE-2025-5915](https://access.redhat.com/security/cve/CVE-2025-5915)",
