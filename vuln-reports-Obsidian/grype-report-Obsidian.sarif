            },
            {
              "id": "CVE-2025-69418-openssl",
              "name": "RpmMatcherExactDirectMatch",
              "shortDescription": {
                "text": "CVE-2025-69418 low vulnerability for openssl package"
              },
              "fullDescription": {
                "text": "A flaw was found in OpenSSL. When applications directly call the low-level CRYPTO_ocb128_encrypt() or CRYPTO_ocb128_decrypt() functions with non-block-aligned lengths in a single call on hardware-accelerated builds, the trailing 1-15 bytes of a message may be exposed in cleartext. These exposed bytes are not covered by the authentication tag, allowing an attacker to read or tamper with them without detection."
              },
              "helpUri": "https://access.redhat.com/security/cve/CVE-2025-69418",
              "help": {
                "text": "Vulnerability CVE-2025-69418\nSeverity: low\nPackage: openssl\nVersion: 1:1.1.1k-15.el8_10\nFix Version: \nType: rpm\nLocation: /var/lib/rpm/Packages\nData Namespace: redhat:distro:redhat:8\nLink: [CVE-2025-69418](https://access.redhat.com/security/cve/CVE-2025-69418)",
