              "id": "CVE-2020-19188-ncurses-base",
              "name": "RpmMatcherExactIndirectMatch",
              "shortDescription": {
                "text": "CVE-2020-19188 low vulnerability for ncurses-base package"
              },
              "fullDescription": {
