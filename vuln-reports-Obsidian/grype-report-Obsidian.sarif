              "id": "CVE-2026-41080-expat",
              "name": "RpmMatcherExactDirectMatch",
              "shortDescription": {
                "text": "CVE-2026-41080 low vulnerability for expat package"
              },
              "fullDescription": {
                "text": "A flaw was found in libexpat. A remote attacker could exploit this vulnerability by providing a specially crafted XML document that leverages insufficient entropy in the hash function. This can lead to hash flooding, a type of Denial of Service (DoS) attack, where the system becomes unresponsive or crashes due to excessive resource consumption."
              },
              "helpUri": "https://access.redhat.com/security/cve/CVE-2026-41080",
