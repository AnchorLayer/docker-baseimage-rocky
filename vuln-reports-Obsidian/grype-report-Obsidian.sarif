            {
              "id": "CVE-2025-30258-gnupg2",
              "name": "RpmMatcherExactDirectMatch",
              "shortDescription": {
                "text": "CVE-2025-30258 low vulnerability for gnupg2 package"
              },
              "fullDescription": {
                "text": "A flaw was found in GnuPG. In affected versions, if a user chooses to import a certificate with certain crafted subkey data that lacks a valid backsig or that has incorrect usage flags, the user loses the ability to verify signatures made from certain other signing keys, leading to a verification denial of service."
              },
