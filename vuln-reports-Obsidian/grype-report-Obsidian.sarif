            {
              "id": "CVE-2019-9937-sqlite-libs",
              "name": "RpmMatcherExactIndirectMatch",
              "shortDescription": {
                "text": "CVE-2019-9937 low vulnerability for sqlite-libs package"
              },
              "fullDescription": {
                "text": "A vulnerability was found in SQLite due to a NULL pointer dereference in the fts5ChunkIterate function within sqlite3.c, where an attacker could exploit this flaw by creating a specially crafted table, causing the application to crash and resulting in a denial of service condition."
              },
              "helpUri": "https://access.redhat.com/security/cve/CVE-2019-9937",
