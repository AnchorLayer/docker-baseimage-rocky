            {
              "id": "CVE-2025-15469-openssl-libs",
              "name": "RpmMatcherExactIndirectMatch",
              "shortDescription": {
                "text": "CVE-2025-15469 low vulnerability for openssl-libs package"
              },
              "fullDescription": {
                "text": "A flaw was found in openssl. When a user signs or verifies files larger than 16MB using the `openssl dgst` command with one-shot algorithms, the tool silently truncates the input to 16MB. This creates an integrity gap, allowing trailing data beyond the initial 16MB to be modified without detection because it remains unauthenticated. This vulnerability primarily impacts workflows that both sign and verify files using the affected `openssl dgst` command."
              },
              "helpUri": "https://access.redhat.com/security/cve/CVE-2025-15469",
              "help": {
                "text": "Vulnerability CVE-2025-15469\nSeverity: low\nPackage: openssl-libs\nVersion: 1:1.1.1k-15.el8_10\nFix Version: \nType: rpm\nLocation: /var/lib/rpm/Packages\nData Namespace: redhat:distro:redhat:8\nLink: [CVE-2025-15469](https://access.redhat.com/security/cve/CVE-2025-15469)",
